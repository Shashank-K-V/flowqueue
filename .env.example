# ── .env.example ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values before running.
# Never commit .env to version control.

# Redis connection URL
# Local Docker:  redis://localhost:6379/0
# Redis Cloud:   redis://:<password>@host:port/0
# Upstash:       rediss://:<password>@host:port/0  (note: rediss:// for TLS)
REDIS_URL=redis://localhost:6379/0

# Queue list key in Redis — change to namespace multiple apps
QUEUE_KEY=flowqueue:jobs

# Job hash key prefix
JOB_HASH_PREFIX=flowqueue:job:

# Worker retry configuration
MAX_RETRIES=3

# How long job hashes survive in Redis after completion (seconds)
TTL_SECONDS=3600

# BLPOP timeout in seconds (how long worker blocks waiting for a job)
BLPOP_TIMEOUT=5

# API server settings (used by uvicorn when running without Docker)
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info
